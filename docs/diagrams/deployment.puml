@startuml
'
' Bourgo Arena — Deployment Architecture
'
!include theme.puml

title Bourgo Arena — Deployment Architecture

' ==============================================================================
' LAYER 1 — Development & CI/CD
' ==============================================================================
partition "Development \\& CI/CD" {
  actor "Developer" as dev

  rectangle "GitHub" as github {
    queue "Develop\nBranch" as develop
    queue "Main\nBranch" as main
  }

  rectangle "GitHub Actions" as gha

  cloud "Laravel Cloud" as cloud {
    rectangle "Staging\nEnvironment" as staging
    rectangle "Production\nEnvironment" as production
  }

  actor "Mobile\nDeveloper" as mobiledev
  cloud "Codemagic" as codemagic
  cloud "App Store /\nPlay Store" as stores

  dev --> develop : git push
  dev --> main : git push (PR merge)
  develop --> gha : trigger
  main --> gha : trigger
  gha --> staging : cloud deploy
  gha --> production : cloud deploy

  mobiledev --> codemagic : git push
  codemagic --> stores : IPA / AAB upload
}

' ==============================================================================
' LAYER 2 — Runtime Environment
' ==============================================================================
partition "Runtime (Laravel Cloud)" {
  rectangle "App Cluster" as cluster {
    component "Octane\n(Caddy / FrankenPHP)" as octane
    component "Scheduler\n(schedule:run)" as scheduler
  }

  queue "Managed Queue" as queue

  database "Postgres" as db {
    frame "Sessions" as sessions
    frame "Cache" as cache
    frame "Queue Jobs" as jobs
    frame "Application\nData" as appdata
  }

  note right of cluster
    PHP stays in memory between requests.
    Scale-to-zero when idle.
  end note

  octane --> scheduler
  octane --> queue : dispatch jobs
  scheduler --> queue : scheduled jobs
  octane --> db : read / write
  queue --> db : persist job data

  octane --> sessions : session state
  octane --> cache : rate limiter state

  rectangle "Filesystem\n(storage/)" as fs
  octane --> fs : uploads, logs, receipts
  note right of fs
    Shared writable filesystem
    across all Cloud replicas.
  end note
}

' ==============================================================================
' LAYER 3 — Consumers
' ==============================================================================
partition "Consumers" {
  actor "Flutter App\n(iOS / Android)" as mobile
  actor "Admin Browser\n(Dashboard)" as browser

  mobile --> octane : HTTPS api.bourgoarena.com
  browser --> octane : HTTPS app.bourgoarena.com

  stores --> mobile : OTA update

  note right of mobile
    **Auth:** Sanctum + Device Token
    **Guard:** Member model
  end note

  note right of browser
    **Auth:** Fortify Session
    **Guard:** User model (Admin/Manager)
  end note
}

@enduml
