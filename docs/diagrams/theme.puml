@startuml
'
' Bourgo Arena — Shared Diagram Theme
'

' --- Colors ---
!define PRIMARY     #2563EB
!define SECONDARY   #7C3AED
!define SUCCESS     #059669
!define WARNING     #D97706
!define DANGER      #DC2626
!define NEUTRAL     #6B7280
!define LIGHT_BG    #F3F4F6
!define DARK_BG     #1F2937
!define WHITE       #FFFFFF

' --- Skin Parameters ---
skinparam backgroundColor $WHITE
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam defaultFontColor $DARK_BG
skinparam shadowing false
skinparam roundCorner 8

' --- Actor ---
skinparam actor {
  BorderColor $PRIMARY
  FontColor $DARK_BG
  FontSize 11
}

' --- Rectangle / Box ---
skinparam rectangle {
  BorderColor $PRIMARY
  BackgroundColor $LIGHT_BG
  FontColor $DARK_BG
  FontSize 11
  RoundCorner 6
}

' --- Cloud ---
skinparam cloud {
  BorderColor $SECONDARY
  BackgroundColor $LIGHT_BG
  FontColor $SECONDARY
  FontSize 11
}

' --- Database ---
skinparam database {
  BorderColor $SUCCESS
  BackgroundColor #ECFDF5
  FontColor $SUCCESS
  FontSize 11
}

' --- Component ---
skinparam component {
  BorderColor $PRIMARY
  BackgroundColor #DBEAFE
  FontColor $DARK_BG
  FontSize 10
}

' --- Queue ---
skinparam queue {
  BorderColor $WARNING
  BackgroundColor #FEF3C7
  FontColor $WARNING
  FontSize 11
}

' --- Arrow ---
skinparam arrow {
  Color $NEUTRAL
  FontColor $NEUTRAL
  FontSize 9
}

' --- Note ---
skinparam note {
  BorderColor $NEUTRAL
  BackgroundColor #F9FAFB
  FontColor $DARK_BG
  FontSize 9
}

' --- Partition / Package ---
skinparam partition {
  BorderColor $NEUTRAL
  BackgroundColor $WHITE
  FontColor $DARK_BG
  FontSize 13
  FontStyle bold
}

' --- Footer ---
footer %filename() — Bourgo Arena
@enduml
