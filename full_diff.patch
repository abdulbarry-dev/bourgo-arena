+                $query->where('plans.id', $plan->id);
+            })->exists()
+        ) {
+            return true;
+        }
+
+        // 3. Any reservations referencing this plan's activities (via services)
+        if (
+            Reservation::whereHas('timeSlot.activity.service', function ($query) use ($plan) {
+                $query->where('id', $plan->service_id);
+            })->exists()
+        ) {
+            return true;
+        }
+
+        return false;
+    }
