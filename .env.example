# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
# APP_NAME: The name of your application.
# APP_ENV: local, staging, or production.
# APP_KEY: Used for encryption. Generate with 'php artisan key:generate'.
# APP_DEBUG: Set to true for development, false for production.
# APP_URL: The base URL of your application.
# ------------------------------------------------------------------------------

APP_NAME="Bourgo Arena"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# Ensure the database exists before running migrations.
# ------------------------------------------------------------------------------

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bourgo_arena
DB_USERNAME=root
DB_PASSWORD=

# ------------------------------------------------------------------------------
# Session & Cache Drivers
# ------------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# ------------------------------------------------------------------------------
# Mail Configuration (Resend)
# ------------------------------------------------------------------------------
# Obtain your API key from https://resend.com
# ------------------------------------------------------------------------------

MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FROM_ADDRESS="hello@example.com"

# ------------------------------------------------------------------------------
# Frontend & Vite
# ------------------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Konnect Payment Gateway
# ------------------------------------------------------------------------------
# Sandbox/Production keys for Konnect integration.
# ------------------------------------------------------------------------------

KONNECT_API_KEY=
KONNECT_API_SECRET=
KONNECT_SANDBOX=true

# ------------------------------------------------------------------------------
# Firebase FCM
# ------------------------------------------------------------------------------
# Path to your Firebase service account JSON file.
# ------------------------------------------------------------------------------

FIREBASE_PROJECT=
FIREBASE_CREDENTIALS=storage/app/firebase-auth.json

# ------------------------------------------------------------------------------
# Twilio (SMS/OTP)
# ------------------------------------------------------------------------------
# Credentials for Twilio SMS integration.
# ------------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ------------------------------------------------------------------------------
# OTP Configuration
# ------------------------------------------------------------------------------

OTP_EXPIRY=10
OTP_LENGTH=6
OTP_RESEND_COOLDOWN_SECONDS=60
