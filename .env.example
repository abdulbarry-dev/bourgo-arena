# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
# APP_NAME: The name of your application.
# APP_ENV: local, staging, or production.
# APP_KEY: Used for encryption. Generate with 'php artisan key:generate'.
# APP_DEBUG: Set to true for development, false for production.
# APP_URL: The base URL of your application.
# ------------------------------------------------------------------------------

APP_NAME="Dashboard"
APP_ENV=testing
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# Ensure the database exists before running migrations.
# ------------------------------------------------------------------------------

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bourgo_arena
DB_USERNAME=root
DB_PASSWORD=

# ------------------------------------------------------------------------------
# Session & Cache Drivers
# ------------------------------------------------------------------------------

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ------------------------------------------------------------------------------
# Mail Configuration (Resend)
# ------------------------------------------------------------------------------
# Obtain your API key from https://resend.com
# ------------------------------------------------------------------------------

MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_NAME="Bourgo Arena"
MAIL_FROM_ADDRESS="hello@example.com"

# ------------------------------------------------------------------------------
# Frontend & Vite
# ------------------------------------------------------------------------------

VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Konnect Payment Gateway
# ------------------------------------------------------------------------------
# Sandbox/Production keys for Konnect integration.
# ------------------------------------------------------------------------------

KONNECT_API_KEY=
KONNECT_API_SECRET=
KONNECT_SANDBOX=true

# ------------------------------------------------------------------------------
# Firebase FCM
# ------------------------------------------------------------------------------
# Path to your Firebase service account JSON file.
# ------------------------------------------------------------------------------

FIREBASE_PROJECT=
FIREBASE_CREDENTIALS=storage/app/firebase-auth.json

# ------------------------------------------------------------------------------
# Twilio (SMS/OTP)
# ------------------------------------------------------------------------------
# Credentials for Twilio SMS integration.
# ------------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ------------------------------------------------------------------------------
# OTP Configuration
# ------------------------------------------------------------------------------

OTP_EXPIRY=10
OTP_LENGTH=6
OTP_RESEND_COOLDOWN_SECONDS=60

# ------------------------------------------------------------------------------
# Device-bound Access Tokens
# ------------------------------------------------------------------------------
# Token TTL in days. Tokens auto-rotate; Flutter must refresh within 7 days of expiry.
DEVICE_TOKEN_TTL=30
# Minimum app version required to consume the API.
MIN_ANDROID_VERSION=1.0.0
MIN_IOS_VERSION=1.0.0
# Bypass token for development/testing integrity verification.
DEV_INTEGRITY_BYPASS_TOKEN=dev-bypass
# Google Play Integrity (service account JSON as a single-line string).
PLAY_INTEGRITY_PROJECT_NUMBER=
PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON=
# Apple App Attest.
APP_ATTEST_TEAM_ID=
APP_ATTEST_BUNDLE_ID=

# Enable web platform access for API in local/testing
API_WEB_PLATFORM_ENABLED=false
